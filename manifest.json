{
  "manifest_version": 3,
  "name": "YouTube Monk Mode",
  "version": "2.0",
  "description": "Blindfold: clean YouTube. Handcuff: full terminal interface.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}
